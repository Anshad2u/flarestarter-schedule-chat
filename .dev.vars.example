# Better-Auth
BETTER_AUTH_SECRET=replace-with-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000
# Email (Resend) — 留空则本地走控制台捕获，不真发
RESEND_API_KEY=
EMAIL_FROM=FlareStarter <onboarding@resend.dev>
# Optional: Resend audience id for the waitlist (and future newsletter).
# Leave blank to disable audience sync — signups still save to D1.
RESEND_AUDIENCE_ID=
# Social OAuth — 留空则该社交按钮不显示
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Stripe（留空则 billing 功能不可用；本地 webhook 用 `stripe listen` 转发）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_LIFETIME=
# Admin（逗号分隔的管理员邮箱；这些邮箱注册/登录即获 admin 角色）
ADMIN_EMAILS=
# Cloudflare Turnstile bot 防护（注册/登录/找回密码）。两个都留空 = 关闭，表单照常工作。
# 在 https://dash.cloudflare.com/?to=/:account/turnstile 创建 widget 获取 keys。
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Cloudflare Web Analytics（隐私友好、免费)。留空 = 不注入 beacon。
# token 在 Dashboard → Analytics & Logs → Web Analytics 获取。
CF_ANALYTICS_TOKEN=
# Sentry 错误上报(服务端)。留空 = 不启用。DSN 在 Sentry 项目设置里获取。
SENTRY_DSN=
